# ─────────────────────────────────────────────────────────────────────────────
# Stella Force — environment variables
# Copy this file to `.env.local` and fill in real values. Never commit secrets.
# ─────────────────────────────────────────────────────────────────────────────

# Supabase project URL (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon/public key — used by the browser client. RLS enforces access.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase service-role key — SERVER ONLY. Bypasses RLS. Never expose to client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic (Claude) API key — SERVER ONLY. Used for AI parsing + embeddings.
ANTHROPIC_API_KEY=sk-ant-your-key

# n8n webhook that parses an uploaded resume — SERVER ONLY.
N8N_WEBHOOK_URL=https://your-n8n-instance.example.com/webhook/parse-resume

# Shared secret sent as `Authorization: Bearer <secret>` to the webhook above — SERVER ONLY.
N8N_WEBHOOK_SECRET=your-n8n-webhook-secret
